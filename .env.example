# ─────────────────────────────────────────────────────────────
# ร้านค้าธรรมกิจ — Environment variables (copy to .env, fill in)
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ร้านค้าธรรมกิจ"

# Database (PostgreSQL) — use a pooled connection string on Vercel
DATABASE_URL="postgresql://user:password@localhost:5432/thammakit?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/thammakit?schema=public"

# NextAuth v5 — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-strong-random-secret"
AUTH_URL="http://localhost:3000"
# OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Stripe
STRIPE_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# Omise (Thai payments — cards, internet banking, TrueMoney)
OMISE_PUBLIC_KEY="pkey_test_xxx"
OMISE_SECRET_KEY="skey_test_xxx"

# PromptPay — merchant identifier (mobile number or National ID / Tax ID)
PROMPTPAY_ID="0812345678"

# Bank transfer display info
BANK_NAME="ธนาคารกสิกรไทย"
BANK_ACCOUNT_NAME="บริษัท ธรรมกิจ จำกัด"
BANK_ACCOUNT_NUMBER="123-4-56789-0"

# Cloudinary
CLOUDINARY_CLOUD_NAME="xxx"
CLOUDINARY_API_KEY="xxx"
CLOUDINARY_API_SECRET="xxx"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="xxx"

# Email (SMTP, e.g. Resend / Mailtrap / Gmail app password)
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_USER="resend"
SMTP_PASSWORD="re_xxx"
EMAIL_FROM="ร้านค้าธรรมกิจ <no-reply@thammakit.com>"

# Analytics
NEXT_PUBLIC_GA_ID="G-XXXXXXX"
NEXT_PUBLIC_META_PIXEL_ID="xxxxxxxxxx"

# Seed admin account
SEED_ADMIN_EMAIL="admin@thammakit.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
