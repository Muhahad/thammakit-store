// ─────────────────────────────────────────────────────────────────────────────
// ร้านค้าธรรมกิจ — Prisma schema
//
// Conventions:
//  • Money is stored as Int in *satang* (1 THB = 100 satang) to avoid float errors.
//    e.g. ฿199.00 => 19900. Format for display with formatTHB() in lib/utils.ts.
//  • cuid() ids everywhere; createdAt/updatedAt on every mutable table.
//  • Thai address model: province / district (อำเภอ) / subdistrict (ตำบล) / zipcode.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING // created, awaiting payment
  PAID // payment confirmed
  PROCESSING // being packed
  SHIPPED // handed to carrier
  DELIVERED // received by customer
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  EXPIRED
}

enum PaymentMethod {
  PROMPTPAY
  STRIPE
  OMISE
  BANK_TRANSFER
}

enum ShippingCarrier {
  FLASH_EXPRESS
  KERRY
  THAILAND_POST
  JT_EXPRESS
}

enum CouponType {
  PERCENTAGE // value = percent off (0–100)
  FIXED // value = satang off
  FREE_SHIPPING
}

// ── Auth (NextAuth v5 Prisma adapter) ────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // null for OAuth-only accounts
  phone         String? // Thai mobile, validated at app layer
  role          Role      @default(CUSTOMER)

  accounts  Account[]
  sessions  Session[]
  addresses Address[]
  orders    Order[]
  reviews   Review[]
  cart      Cart?
  wishlist  WishlistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Catalog ──────────────────────────────────────────────────────────────────

model Category {
  id          String     @id @default(cuid())
  name        String // Thai display name
  nameEn      String?
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

model Product {
  id            String  @id @default(cuid())
  name          String
  nameEn        String?
  slug          String  @unique
  description   String  @db.Text
  descriptionEn String? @db.Text
  // Specifications stored as JSON: [{ "label": "น้ำหนัก", "value": "500 ก." }, ...]
  specs         Json?

  price         Int // selling price, satang
  compareAtPrice Int? // original/strike-through price, satang
  costPrice     Int? // internal cost, satang (admin only)
  sku           String  @unique
  barcode       String?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  images    ProductImage[]
  inventory Inventory?
  reviews   Review[]
  orderItems OrderItem[]
  cartItems CartItem[]
  wishlistItems WishlistItem[]

  // Merchandising flags for homepage sections
  isActive     Boolean @default(true)
  isFeatured   Boolean @default(false)
  isNewArrival Boolean @default(false)
  isBestSeller Boolean @default(false)

  weightGrams Int     @default(500) // for shipping calculation
  ratingAvg   Float   @default(0) // denormalized for fast sorting/display
  ratingCount Int     @default(0)
  soldCount   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([isFeatured])
  @@index([isNewArrival])
  @@index([isBestSeller])
  @@index([price])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String // Cloudinary secure_url
  publicId  String // Cloudinary public_id (for deletion)
  alt       String?
  position  Int     @default(0)

  @@index([productId])
}

model Inventory {
  id           String  @id @default(cuid())
  productId    String  @unique
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity     Int     @default(0) // on-hand stock
  reserved     Int     @default(0) // reserved by pending orders
  lowStockThreshold Int @default(5)

  updatedAt DateTime @updatedAt
}

// ── Cart (persistent, per user) ──────────────────────────────────────────────

model Cart {
  id     String     @id @default(cuid())
  userId String     @unique
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)

  createdAt DateTime @default(now())

  @@unique([cartId, productId]) // one row per product per cart
  @@index([productId])
}

// ── Wishlist ─────────────────────────────────────────────────────────────────

model WishlistItem {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// ── Addresses (Thai model) ───────────────────────────────────────────────────

model Address {
  id           String  @id @default(cuid())
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName     String
  phone        String // Thai mobile
  line1        String // house no. / village / soi / road
  subdistrict  String // ตำบล / แขวง
  district     String // อำเภอ / เขต
  province     String // จังหวัด
  zipcode      String // 5 digits
  isDefault    Boolean @default(false)

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique // human-friendly, e.g. TK-20260704-0001
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  status      OrderStatus @default(PENDING)

  items     OrderItem[]
  payment   Payment?

  // Snapshot of shipping address at time of order (immutable record)
  addressId    String?
  address      Address? @relation(fields: [addressId], references: [id])
  shipName     String
  shipPhone    String
  shipLine1    String
  shipSubdistrict String
  shipDistrict String
  shipProvince String
  shipZipcode  String

  // Money breakdown — all satang
  subtotal     Int // sum of line items (VAT-inclusive base)
  discount     Int @default(0) // coupon discount
  shippingFee  Int @default(0)
  vatAmount    Int @default(0) // 7% VAT component (informational; prices VAT-inclusive)
  total        Int // amount charged

  couponId   String?
  coupon     Coupon? @relation(fields: [couponId], references: [id])
  couponCode String?

  carrier        ShippingCarrier?
  trackingNumber String?
  shippedAt      DateTime?
  deliveredAt    DateTime?

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  // Snapshot fields — preserve name/price even if product changes later
  name      String
  image     String?
  unitPrice Int // satang, at purchase time
  quantity  Int

  @@index([orderId])
  @@index([productId])
}

// ── Payments ─────────────────────────────────────────────────────────────────

model Payment {
  id        String        @id @default(cuid())
  orderId   String        @unique
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method    PaymentMethod
  status    PaymentStatus @default(PENDING)
  amount    Int // satang
  currency  String        @default("THB")

  // Gateway references
  providerRef String? // Stripe PaymentIntent id / Omise charge id
  promptpayPayload String? @db.Text // EMVCo QR payload for PromptPay
  slipUrl     String? // uploaded bank-transfer slip (Cloudinary)

  paidAt    DateTime?
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// ── Coupons ──────────────────────────────────────────────────────────────────

model Coupon {
  id          String     @id @default(cuid())
  code        String     @unique // uppercase, e.g. WELCOME10
  description String?
  type        CouponType
  value       Int // percent (0–100) OR satang, depending on type
  minSpend    Int        @default(0) // minimum subtotal (satang) to qualify
  maxDiscount Int? // cap for percentage coupons (satang)

  usageLimit  Int? // total redemptions allowed (null = unlimited)
  usedCount   Int        @default(0)
  perUserLimit Int?      // redemptions per user

  startsAt DateTime?
  endsAt   DateTime?
  isActive Boolean  @default(true)

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Reviews ──────────────────────────────────────────────────────────────────

model Review {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int // 1–5
  title     String?
  comment   String? @db.Text
  isApproved Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, userId]) // one review per product per user
  @@index([productId])
}
